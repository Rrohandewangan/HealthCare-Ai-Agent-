# ─── Core ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SIGNALING_PORT=3001
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:19006

# ─── MongoDB Atlas ───────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net

# ─── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
JWT_ISSUER=vitalis-ai
JWT_AUDIENCE=vitalis-clients

# ─── Azure AI Foundry (GPT models) ───────────────────────
# Recommended deployments (in your Foundry tenant):
#   gpt-4.1-mini   → cheap, fast, supports json_schema  (DEFAULT for triage)
#   gpt-4.1        → higher quality
#   gpt-5-mini     → newer, structured outputs (use api-version 2025-01-01-preview)
#   gpt-5-nano     → cheapest GPT-5 tier
# DO NOT use chat-only variants (gpt-5-chat, gpt-4o-realtime, audio, image, embedding).
AI_PROVIDER=azure-foundry
AI_ENDPOINT=https://your-resource.openai.azure.com
AI_KEY=your-foundry-key
AI_DEPLOYMENT=gpt-4.1-mini
AI_API_VERSION=2024-10-21
AI_TIMEOUT_MS=20000

# ─── Google Maps ─────────────────────────────────────────
MAPS_PROVIDER=google
MAPS_API_KEY=your-google-maps-key

# ─── Azure Blob Relay ────────────────────────────────────
RELAY_PROVIDER=azure-blob
AZURE_STORAGE_ACCOUNT=yourstorageacct
AZURE_STORAGE_KEY=base64-key
AZURE_STORAGE_CONTAINER=sync-relay
RELAY_TTL_HOURS=24

# ─── Rate limits ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AI_RATE_LIMIT_MAX=30
